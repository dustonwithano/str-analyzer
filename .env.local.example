# Required — get from https://upstash.com (free tier available)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required — get from https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=

# Optional — get from https://rapidapi.com/apimaker/api/zillow-com1 (paid)
# Without this, property data (price, beds, baths) will not be pre-filled
RAPIDAPI_KEY=

# Optional — get from https://app.rentcast.io (paid)
# Without this, LTR rent estimates will not be available
RENTCAST_API_KEY=

# Optional — get from https://www.airroi.com/api/developer/activate (free starter credits, ~$0.01/call)
# Without this, STR market data uses realistic mock values for Wells, Maine (04090)
AIRROI_API_KEY=

# Optional — get from https://fred.stlouisfed.org/docs/api/api_key.html (free)
# Without this, mortgage rate defaults to ~6.95%
FRED_API_KEY=

# Optional — get from https://console.cloud.google.com (pay-per-use, generous free tier)
# Enables: address geocoding, location scoring, street view images, places photos
# Without this, location intelligence and property images will use placeholders
GOOGLE_MAPS_API_KEY=
